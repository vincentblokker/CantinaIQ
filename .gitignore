# Track-specific generated artefacts.
# Note: bare/output/ is COMMITTED so examiners see results without running
# the notebook. Supercharged generated artefacts are gitignored — they
# regenerate deterministically from `uv run cantinaiq run all`.
supercharged/data/interim/
supercharged/data/processed/
supercharged/data/exports/
supercharged/data/runs/
supercharged/reports/generated/

*.parquet
*.duckdb

# Python tooling caches (apply to both tracks)
.coverage
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/

# TypeScript incremental build cache — local artifact, regenerates on build.
**/tsconfig.tsbuildinfo

# Deploy artefacts — rebuild with deploy/package.sh whenever needed.
cantinaiq-dashboard.tar.gz

# PDF render previews — temporary visual checks, not source of truth.
deploy/*/preview/

# Local briefings + scratchpad notes that aren't project artefacts.
BRIEFING-*.md
